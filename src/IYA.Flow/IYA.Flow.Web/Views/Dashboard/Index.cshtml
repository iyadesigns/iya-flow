@model IYA.Flow.Web.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="workspace-card mb-4">

    <h1>
        Welcome to IYA.Flow 🦋
    </h1>

    <p>
        Flow through your work.
    </p>

</div>

<div class="row">

    <div class="col-md-3 mb-4">

        <div class="card shadow-sm h-100">

            <div class="card-body text-center">

                <h1>🦋</h1>

                <h2>@Model.TotalWorkspaces</h2>

                <p class="text-muted">
                    Workspaces
                </p>

            </div>

        </div>

    </div>

    <div class="col-md-3 mb-4">

        <div class="card shadow-sm h-100">

            <div class="card-body text-center">

                <h1>📁</h1>

                <h2>@Model.TotalProjects</h2>

                <p class="text-muted">
                    Projects
                </p>

            </div>

        </div>

    </div>

    <div class="col-md-3 mb-4">

        <div class="card shadow-sm h-100">

            <div class="card-body text-center">

                <h1>✅</h1>

                <h2>@Model.TotalTasks</h2>

                <p class="text-muted">
                    Tasks
                </p>

            </div>

        </div>

    </div>

    <div class="col-md-3 mb-4">

        <div class="card shadow-sm h-100">

            <div class="card-body text-center">

                <h1>📝</h1>

                <h2>@Model.TotalNotes</h2>

                <p class="text-muted">
                    Notes
                </p>

            </div>

        </div>

    </div>

</div>