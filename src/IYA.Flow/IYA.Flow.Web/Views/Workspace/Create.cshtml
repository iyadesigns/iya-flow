@model IYA.Flow.Application.DTOs.Workspace.CreateWorkspaceDto

@{
    ViewData["Title"] = "New Workspace";
}

<div class="workspace-form">

    <div class="workspace-header">

        <h2>Create Workspace</h2>

        <p>
            Organize your projects inside beautiful workspaces.
        </p>

    </div>

    <form asp-action="Create" method="post">

        <!-- Workspace Name -->
        <div class="mb-4">

            <label asp-for="Name" class="form-label"></label>

            <input asp-for="Name"
                   class="form-control" />

            <span asp-validation-for="Name"
                  class="text-danger"></span>

        </div>

        <!-- Description -->
        <div class="mb-4">

            <label asp-for="Description"
                   class="form-label"></label>

            <textarea asp-for="Description"
                      rows="4"
                      class="form-control"></textarea>

            <span asp-validation-for="Description"
                  class="text-danger"></span>

        </div>

        <!-- Color -->
        <div class="mb-4">

            <label asp-for="Color"
                   class="form-label"></label>

            <input asp-for="Color"
                   type="color"
                   class="form-control form-control-color" />

        </div>

        <!-- Icon Selector -->
        <div class="mb-4">

            <label class="form-label">

                Workspace icon

            </label>

            <div class="icon-grid">

                @{
                    string[] icons =
                    {
                        "folder",
                        "briefcase",
                        "rocket",
                        "star",
                        "calendar",
                        "notebook-pen",
                        "heart",
                        "graduation-cap"
                    };
                }

                @foreach (var icon in icons)
                {
                    <label class="icon-option">

                        <input asp-for="Icon"
                               type="radio"
                               value="@icon"
                               class="d-none" />

                        <div class="icon-card">

                            <i data-lucide="@icon"></i>

                        </div>

                    </label>
                }

            </div>

        </div>

        <!-- Favorite -->
        <div class="form-check mb-4">

            <input asp-for="IsFavorite"
                   class="form-check-input" />

            <label asp-for="IsFavorite"
                   class="form-check-label">
                Mark as favorite
            </label>

        </div>

        <!-- Buttons -->
        <div class="d-flex gap-3">

            <button class="btn btn-primary">

                Create Workspace

            </button>

            <a asp-action="Index"
               class="btn btn-outline-secondary">

                Cancel

            </a>

        </div>

    </form>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>

        lucide.createIcons();

    </script>
}