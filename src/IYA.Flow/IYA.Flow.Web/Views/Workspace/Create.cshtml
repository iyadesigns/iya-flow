@model IYA.Flow.Core.Entities.Workspace

@{
    ViewData["Title"] = "Nuevo Workspace";
}

<div class="container mt-4">

    <h2>Nuevo Workspace</h2>
    <hr />

    <form asp-action="Create" method="post">

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Color" class="form-label"></label>
            <input asp-for="Color" type="color" class="form-control form-control-color" />
        </div>

        <div class="mb-3">
            <label asp-for="Icon" class="form-label"></label>
            <input asp-for="Icon" class="form-control" placeholder="🦋" />
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsFavorite" class="form-check-input" />
            <label asp-for="IsFavorite" class="form-check-label">
                Marcar como favorito
            </label>
        </div>

        <button type="submit" class="btn btn-primary">
            Guardar Workspace
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancelar
        </a>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}