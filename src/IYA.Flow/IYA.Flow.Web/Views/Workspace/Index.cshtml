@model IEnumerable<IYA.Flow.Application.DTOs.Workspace.WorkspaceDto>

@{
    ViewData["Title"] = "Workspaces";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <!-- Page Header -->
    <div>

       @*  <h2>🦋 Workspaces</h2> *@
        🦋 Workspaces

        <span class="badge bg-dark ms-2">

            @Model.Count()

        </span>

        <p class="text-muted mb-0">
            Organize your projects into elegant workspaces.
        </p>

    </div>

    <!-- Create Workspace Button -->
    <a asp-action="Create" class="btn btn-primary">

        <i data-lucide="plus"></i>

        New Workspace

    </a>

</div>

@if (!Model.Any())
{
    <div class="alert alert-info">

        <strong>No workspaces found.</strong>

        Create your first workspace to start organizing your projects.

    </div>
}
else
{
    <div class="row">

        @foreach (var workspace in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">

                <div class="card shadow-sm border-0 h-100">

                    <div class="card-body">

                        <!-- Workspace Header -->
                        <div class="d-flex justify-content-between align-items-center mb-3">

                            <h5 class="card-title mb-0">

                                <i data-lucide="@workspace.Icon"></i>

                                @workspace.Name

                            </h5>

                            @if (workspace.IsFavorite)
                            {
                                <span class="fs-5" title="Favorite">

                                    ⭐

                                </span>
                            }

                        </div>

                        <!-- Description -->
                        <p class="text-muted">

                            @workspace.Description

                        </p>

                        <!-- Workspace Color -->
                      @*   <div class="mb-4">

                            <span class="badge rounded-pill"
                                  style="background-color:@workspace.Color">

                                @workspace.Color

                            </span>

                        </div> *@

                        <div class="d-flex align-items-center gap-2">

                            <div class="color-dot"
                                 style="background:@workspace.Color">
                            </div>

                            <small class="text-muted">

                                @* Theme color *@

                            </small>

                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex justify-content-between">

                            <a asp-action="Details"
                               asp-route-id="@workspace.Id"
                               class="btn btn-outline-primary btn-sm">

                                <i data-lucide="eye"></i>

                               @*  Details *@

                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@workspace.Id"
                               class="btn btn-outline-warning btn-sm">

                                <i data-lucide="pencil"></i>

                               @*  Edit *@

                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@workspace.Id"
                               class="btn btn-outline-danger btn-sm">

                                <i data-lucide="trash-2"></i>

                               @*  Delete *@

                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>
}

@section Scripts
{
    <script>
        lucide.createIcons();
    </script>
}