<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - IYA.Flow</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/workspace.css" asp-append-version="true" />

</head>

<body>

    <div class="app">

        <aside class="sidebar">

            <div class="logo">

                🦋

                <div>

                    <h2>IYA.Flow</h2>

                    <span>Flow through your work.</span>

                </div>

            </div>

            <nav>

                <a asp-controller="Dashboard" asp-action="Index">
                    Dashboard
                </a>

                <a asp-controller="Workspace" asp-action="Index">
                    Workspaces
                </a>

                <a href="#">
                    Projects
                </a>

                <a href="#">
                    Tasks
                </a>

                <a href="#">
                    Calendar
                </a>

                <a href="#">
                    Notes
                </a>

                <a href="#">
                    AI Assistant
                </a>

                <a href="#">
                    Settings
                </a>

            </nav>

        </aside>

        <div class="main">

            <header class="topbar">

                <div>

                    <h3>@ViewData["Title"]</h3>

                    <span>Designed with elegance & purpose.</span>

                </div>

            </header>

            <main class="content">

                @RenderBody()

            </main>

        </div>

    </div>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>